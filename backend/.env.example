# LLM providers. Gemini = primary (CEO + Technical). Groq/Cerebras = free
# fallback + research. Get keys at:
# Gemini:   https://aistudio.google.com/apikey   (เปิด billing เพื่อไม่ให้ quota=0)
# Groq:     https://console.groq.com/keys        (ฟรี)
# Cerebras: https://cloud.cerebras.ai            (ฟรี)
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Dashboard password — ตั้งค่านี้บน VPS เพื่อล็อกหน้าเว็บ (ใครรู้ IP ก็เข้าไม่ได้
# ถ้าไม่มีรหัส). เว้นว่าง = ไม่มีรหัส (เฉพาะ dev บนเครื่องตัวเอง)
DASHBOARD_PASSWORD=

# เพดานงบ Gemini ต่อเดือน (บาท) — พอใช้ถึงเพดาน ระบบหยุดเรียก Gemini เอง
# แล้ว fallback ไป Groq/Cerebras (ฟรี). ป้องกันบิลบานจากฝั่งโค้ด. default 550
GEMINI_MONTHLY_BUDGET_THB=550

# (ไม่บังคับ) รายชื่อ symbol ที่ MT5 Python จะดึง — คั่นด้วยคอมมา
# ถ้าไม่ตั้ง ใช้ค่า default: EURUSD,GBPUSD,USDJPY,XAUUSD,US30,NAS100
# MT5_SYMBOLS=EURUSD,GBPUSD,USDJPY,XAUUSD
